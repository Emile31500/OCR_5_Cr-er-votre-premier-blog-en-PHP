{% extends 'layout.twig' %}

{% block title %}
    {{title}}
{% endblock %}

{% block style_sheet %}
    <link href="http://127.0.0.1/Projet%20OC5/style/accueil.css" rel="stylesheet"/>
{% endblock %}

{% block content%}
    
    <div class="section">
        <div class="row">
            <div class="text-center align-items-centergit col col-sm-3 col-4">
                <img class="photo_accueil" height="300" width="533" src="http://127.0.0.1/Projet%20OC5/media/image/emilearmengaud.jpg">
            </div>
            <div class="col col-sm-9 col-8">
                <h2>
                    Emile : Développeur web php/Symfony
                </h2>
                <span class="lead">
                    
                    {% for paragraphe in description %}
                        <p>
                            {{paragraphe}}
                        </p>
                    {% endfor %}
                
                </span>
            </div>
        </div>
    </div>
    <div class="section">
        <h3 class="online-title" style=""> CV : </h3> <img class="cv_icon" src="http://127.0.0.1/Projet%20OC5/media/image/icone/icon_pdf.png">
    </div>
    <div class="section">
        <form id="send_message_form" method="post" action="http://127.0.0.1/Projet%20OC5/messages/envoyer">
            <h3>
                Contact :
            </h3>
            <div>
                <div class="row form-group">
                    <div class="col-6">
                        <label>
                            Nom :
                        </label> 
                        <br>
                        <input require type="text" id="name" name="name"/>
                    </div>
                    <div class="col-6">
                        <label>
                            Prénom : 
                        </label> 
                        <br>
                        <input placeholder type="text" id="firstname" name="firstname">
                    </div>
                </div>
                <div class="form-group">
                    <label>
                        Email :
                    </label>
                    <br>
                    <input placeholder type="email" id="email" name="email"> 
                </div>
                <div class="form-group">
                    <label>
                        Objet :
                    </label>
                    <br>
                    <input type="text" id="objet" name="objet"> 
                </div>
                <div class="form-group">
                    <label>
                        Message :
                    </label>
                    <br>
                    <textarea placeholder id="message" name="message">
                    </textarea> 
                </div>
                <div  class="form-group text-end">
                    <input class="btn btn-primary" type="submit">             
                </div>
            </div>
        </form>
        <div class="alert">
        </div>
    </div>
{% endblock %}
{% block javascript_link %}
    <script src="http://127.0.0.1/Projet%20OC5/JS/form_contact.js"></script>
{% endblock %}